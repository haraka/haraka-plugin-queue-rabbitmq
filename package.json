{
  "name": "haraka-plugin-queue-rabbitmq",
  "version": "1.0.0",
  "description": "Haraka plugin that delivers emails to rabbitmq",
  "main": "index.js",
  "files": [
    "CHANGELOG.md",
    "config"
  ],
  "scripts": {
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint": "npx eslint *.js test",
    "lint:fix": "npx eslint *.js test --fix",
    "prettier": "npx prettier . --check",
    "prettier:fix": "npx prettier . --write --log-level=warn",
    "test": "node --test",
    "versions": "npx dependency-version-checker check",
    "versions:fix": "npx dependency-version-checker update"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haraka/haraka-plugin-queue-rabbitmq.git"
  },
  "keywords": [
    "haraka-plugin",
    "queue-rabbitmq"
  ],
  "author": "Welcome Member <happy-haraka-hacker@example.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/haraka/haraka-plugin-queue-rabbitmq/issues"
  },
  "homepage": "https://github.com/haraka/haraka-plugin-queue-rabbitmq#readme",
  "dependencies": {
    "amqp": "^0.2.7",
    "amqplib": "^0.10.9"
  },
  "devDependencies": {
    "@haraka/eslint-config": "^2.0.2",
    "haraka-test-fixtures": "^1.3.10"
  },
  "prettier": {
    "singleQuote": true,
    "semi": false
  }
}